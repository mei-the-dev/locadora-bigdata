# ============================================================================
# .env.example - Solucao Big Data para Frota Autonoma Conectada (Avaliacao 03)
# Grupo: Izabela Lima da Silva (124156557) - Caio Meirelles (122071557)
# Copie para `.env` (cp .env.example .env) antes de `make up-core`.
# Heaps e limites explicitos dimensionados para caber em 16 GB (perfil core).
# ============================================================================

# --- Simulador de frota (Camada 0 - Edge) -----------------------------------
FLEET_NUM_VEICULOS=12            # veiculos autonomos simulados
FLEET_SEED=42                    # semente deterministica (reprodutibilidade)
FLEET_EDGE_WINDOW=10             # leituras cruas por pacote agregado (combiner)
FLEET_EMIT_INTERVAL_S=1.0        # intervalo entre leituras cruas (segundos)
FLEET_DESORDEM_MAX_MS=3000       # atraso maximo injetado (exercita watermarks)
FLEET_PROB_EMERGENCIA=0.02       # probabilidade de cenario de emergencia por ciclo

# --- MQTT (Mosquitto) -------------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC_TELEMETRIA=frota/telemetria
MQTT_TOPIC_EMERGENCIA=frota/emergencia
MQTT_TOPIC_VIAGEM=frota/viagem

# --- Kafka / Redpanda (barramento de log) -----------------------------------
KAFKA_BROKER=redpanda:9092
KAFKA_TOPIC_TELEMETRIA=telemetry
KAFKA_TOPIC_EMERGENCIA=emergency
KAFKA_TOPIC_VIAGEM=trip
KAFKA_PARTICOES=6                # particao por vehicle_id (ordem estrita R1)

# --- MinIO (object store S3 do Lakehouse) -----------------------------------
MINIO_ROOT_USER=fleetadmin
MINIO_ROOT_PASSWORD=fleetsecret123
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=lakehouse

# --- PostgreSQL (camada GOLD = DW estendido + pgvector) ---------------------
POSTGRES_HOST=postgres-gold
POSTGRES_PORT=5432
POSTGRES_DB=dw
POSTGRES_USER=dw
POSTGRES_PASSWORD=dwsecret
POSTGRES_SCHEMA=dw_locadora

# --- Cassandra (telemetria - wide-column) -----------------------------------
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=frota
CASSANDRA_MAX_HEAP=1G            # heap fixo p/ conter a JVM (risco de OOM)
CASSANDRA_HEAP_NEWSIZE=200M

# --- MongoDB (cadastrais + dossies) -----------------------------------------
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=frota
MONGO_INITDB_ROOT_USERNAME=frota
MONGO_INITDB_ROOT_PASSWORD=frotasecret

# --- Redis (cache do dashboard) ---------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_S=15                   # staleness limitado (delta consistency)

# --- Spark / Flink heaps ----------------------------------------------------
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g
FLINK_TM_SLOTS=2

# --- Neo4j (perfil full - roteirizacao) -------------------------------------
NEO4J_AUTH=neo4j/frotaneo4j
NEO4J_HEAP=512M

# --- Streamlit dashboard ----------------------------------------------------
STREAMLIT_PORT=8501
